{
  "name": "kanji-puzzle-game",
  "version": "1.0.0",
  "description": "A web puzzle game for learning Japanese kanji characters",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:data && vite build",
    "build:data": "tsx scripts/parse-kanjis.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "preview": "vite preview",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "tsx": "^4.7.0"
  }
}
